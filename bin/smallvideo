#!/usr/bin/env bash

# usage smallvideo videofile.mp4 (res:1080) (quality:1-51, 1 is high) (includeaudio:1|0)

# bash "strict mode"
set -eu

# input
	input=$1
	size=${2:-1080}
	crf=${3:-25}
	audio=${4:0}

# vars
	extension=mp4
	inputNameWithoutExtension=${input%.*}
	timestamp="$(date +%s)"
	[[ $audio == 1 ]] && audioString="audio" || audioString="noaudio";
	outfile="./${inputNameWithoutExtension}-${size}-q${crf}-${audioString}-${timestamp}.${extension}"

# sets audioArg based on $audio boolean
[[ $audio == 1 ]] && audioArg="" || audioArg="-an";

ffmpeg \
	-i $input \
	-c:v libx264 \
	-crf $crf \
	-preset veryslow \
	-vf scale=-2:$size \
	$audioArg \
	-movflags faststart \
	-loglevel warning \
	-hide_banner -stats \
	"$outfile";

echo "created $outfile";

# -vf scale=-2:720 = -2 is for even number of pixels, -1 allows odd number