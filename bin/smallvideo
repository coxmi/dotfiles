#!/usr/bin/env bash

set -euo pipefail

# defaults
size=1080
crf=25
audio=0
input=""

print_usage() {
    echo ""
    echo "Usage:"
    echo "  smallvideo <input> --size 1080 --crf 25 --audio 1|0"
    echo ""
    echo "  crf range"
    echo "  0 → lossless"
    echo "  25 → medium compression (default)"
    echo "  51 → maximum compression"
    exit 1
}

# parse args
while [[ $# -gt 0 ]]; do
    case "$1" in
        --size)
            size="$2"
            shift 2
            ;;
        --crf)
            crf="$2"
            shift 2
            ;;
        --audio)
            audio="$2"
            shift 2
            ;;
        --help)
            print_usage
            ;;
        --*)
            echo "Unknown option: $1"
            print_usage
            ;;
        *)
            if [[ -z "$input" ]]; then
                input="$1"
            else
                echo "Unexpected extra positional argument: $1"
                print_usage
            fi
            shift
            ;;
    esac
done

# validate
if [[ -z "$input" ]]; then
    echo "Missing input file"
    print_usage
fi

# vars
extension="mp4"
filename="$(basename "$input")"
inputNameWithoutExtension="${filename%.*}"

# resolve input directory (absolute path)
inputDir="$(cd "$(dirname "$input")" && pwd)"

timestamp="$(date +%s)"

if [[ "$audio" = "1" ]]; then
    audioString="audio"
    audioArgs=()
else
    audioString="noaudio"
    audioArgs=(-an)
fi

outfile="${inputDir}/${inputNameWithoutExtension}-${size}-q${crf}-${audioString}-${timestamp}.${extension}"

ffmpeg \
    -i "$input" \
    -c:v libx264 \
    -crf "$crf" \
    -preset veryslow \
    -vf "scale=-2:$size" \
    "${audioArgs[@]}" \
    -movflags faststart \
    -loglevel warning \
    -hide_banner -stats \
    "$outfile"

echo "created $outfile"