#!/usr/bin/env bash

BIN_NAME=$(basename "$0")
COMMAND_NAME=$1
SUB_COMMAND_NAME=$2


# command help

	sub_help() {
		echo "Usage: $BIN_NAME <command>"
		echo
		echo "Commands:"
		echo "-  files       Copies dotfiles (\${folder}/.*) to ~ if they don’t already exist"
		echo "-  install     View list of install scripts at (\${folder}/install)"
		echo "-  install <x> Run install script"
		echo "-  macOS       Apply macOS system defaults (requires reboot)"
		echo "-  dock        Empty dock on macOS"
		echo "-  help        This help message"
	}


# command: files

	link_file() {
		if [ -e "$2" ]; then
			if [ "$(readlink "$2")" = "$1" ]; then
				message success "skipped $1"
				return 0
			else
				mv "$2" "$2.backup"
				message success "moved $2 to $2.backup"
			fi
		fi
		ln -sf "$1" "$2"
		message success "linked $1 to $2"
	}

	sub_files() {
		echo $1
	    message info "copying dotfiles ($DOTFILES/{folder}/.*) to ~"

	    # Use find to locate files AND directories, excluding unwanted stuff
	    find -H "$DOTFILES" \
		    -name '.*' \
	    	-mindepth 2 \
	    	-maxdepth 2 \
	        ! -path '*/.git/*' \
	        ! -name '*.DS_Store' | while read -r src; do
	       	
	       	relativeSrc="${src#$HOME/}"
	        # Strip the DOTFILES prefix and the first folder name, e.g.:
            # ~/dotfiles/vim/.vimrc -> ~/.vimrc
            # ~/dotfiles/vim/.config/nvim -> ~/.config/nvim
            relativeDest="${src#$DOTFILES/}"
            relativeDest="${relativeDest#*/}"
	        dest="$HOME/$relativeDest"

	        if [ -d "$src" ]; then
	        	if [[ ! -d "$dest" || "$1" == "--force" ]]; then
		        	mkdir -p "$dest"
					cp -R "$src/"* "$dest/" \
						&& message success "copied $relativeSrc to ~/$relativeDest" \
						|| message fail "copy $relativeSrc to ~/$relativeDest failed"
	        	else
	        		message info "folder $dest already exists (use --force to overwrite)"
	        	fi
	        else
	        	if [[ ! -e "$dest" || "$1" == "--force" ]]; then
	        		cp "$src" "$dest" \
		        		&& message success "copied $relativeSrc to ~/$relativeDest" \
		        		|| message fail "copy $relativeSrc to ~/$relativeDest failed"
	        	else
	        		message info "file $dest already exists (use --force to overwrite)"
	        	fi
	        fi
	    done
	}


# command: install

	sub_install() {
		local toInstall=$1
		if [ -z "$toInstall" ]; then
			# no arg, list installers
			echo 'Use: dotfiles install <installer>, with:';
			list_install_scripts
		else
			# arg exists
			if test $(find -H "$DOTFILES/$toInstall" -depth 1 -name 'install' 2> /dev/null | wc -c) -eq 0; then
				# no installers found
				echo "No installer found called \`$toInstall\`, use with:"
				list_install_scripts
			else
				# Ask for the administrator password upfront, and keep alive
				# (update existing `sudo` time stamp until we're finished)
				sudo -v
				while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &


				# found installer, run scripts
				local preinstaller="$DOTFILES/$toInstall/preinstall"
				local installer="$DOTFILES/$toInstall/install"
				local postinstaller="$DOTFILES/$toInstall/postinstall"

				if [ -e $preinstaller ]; then
					${preinstaller} && message success "$preinstaller completed" || message fail "$preinstaller failed"
				fi

				if [ -e $installer ]; then
					${installer} && message success "$installer completed" || message fail "$installer failed"
				fi

				if [ -e $postinstaller ]; then
					${postinstaller} && message success "$postinstaller completed" || message fail "$postinstaller failed"
				fi
			fi
		fi
	}

	list_install_scripts() {
		for installer in $(find -H "$DOTFILES" -mindepth 2 -maxdepth 2 -name 'install' | sort); do
			local name=${installer/#"$DOTFILES"}
			local prefix="$DOTFILES/"
			local suffix="/install"
			name=${installer#"$prefix"}
			name=${name%"$suffix"}
			echo "• $name"
		done
	}



# command: macOS

	sub_macOS() {
		bash $DOTFILES/macOS/macOS
	}


# command: dock

	sub_dock() {
		# Wipe all (default) app icons from the Dock
		defaults write com.apple.dock persistent-apps -array && killall Dock
	}


# run

	case $COMMAND_NAME in
		"" | "-h" | "--help")
	    	sub_help
	    	;;
	  	*)
			shift
			if typeset -f "sub_${COMMAND_NAME}" > /dev/null; then
				sub_${COMMAND_NAME} "$@"
			else
				message fail "command '$COMMAND_NAME' is not a known command. try '$BIN_NAME help'." >&2
			fi
	    	;;
	esac
