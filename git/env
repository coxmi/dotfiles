#!/usr/bin/env bash


function git_prompt() {
    local dirtyCount
    local branchStatus
    local gitStatus=""
    dirtyCount=$(git_dirty_count)
    branchStatus=$(git_branch_status)
    if [[ -n "$dirtyCount" ]]; then gitStatus+=" ${dirtyCount}"; fi
    if [[ -n "$branchStatus" ]]; then gitStatus+=" $branchStatus"; fi
    if [[ -n "$gitStatus" ]]; then echo "$gitStatus " | tr -s ' '; fi
}

function git_dirty_count() {
	local dirtyCount=0

	# Only run in a Git repo
	if git rev-parse --is-inside-work-tree &>/dev/null; then
	     if [[ "$(git rev-parse --is-inside-git-dir 2>/dev/null)" == 'false' ]]; then
	     	dirtyCount=$(
	     	    (
	     	        git diff --name-only --ignore-submodules
	     	        git diff --cached --name-only --ignore-submodules
	     	        git ls-files --others --exclude-standard
	     	    ) | sort -u | grep -c .
	     	)
	     	dirtyCount="${dirtyCount//[^0-9]/}"
	     	dirtyCount="${dirtyCount:-0}"
	     	if (( dirtyCount > 0 )); then
	     		echo "($dirtyCount)";
	     	fi
	     fi
	fi
}

function git_branch_status() {
	local branchName=''
	local remoteStatus=''

	if git rev-parse --is-inside-work-tree &>/dev/null; then
		if [[ "$(git rev-parse --is-inside-git-dir 2>/dev/null)" == 'false' ]]; then
			branchName="$(
				git symbolic-ref --quiet --short HEAD 2>/dev/null || \
			    git rev-parse --short HEAD 2>/dev/null || \
			    echo '(detached)'
			)"

			# Remote ahead/behind
			if git rev-parse --abbrev-ref --symbolic-full-name @{u} &>/dev/null; then
			    local ahead behind
			    behind=$(git rev-list --count HEAD..@{u} 2>/dev/null | tr -d ' ')
			    ahead=$(git rev-list --count @{u}..HEAD 2>/dev/null | tr -d ' ')
			    remoteStatus=''
			    [[ "$ahead" -gt 0 ]] && remoteStatus+="↑${ahead}"
			    [[ "$behind" -gt 0 ]] && remoteStatus+="↓${behind}"
			fi

			echo "${remoteStatus} ${branchName}"
		fi
	fi
}
